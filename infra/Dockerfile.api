# PricePilot API — production image.
#   docker build -f infra/Dockerfile.api -t pricepilot-api .
# Provide DATABASE_URL (+ optional vendor/VAPID/Anthropic keys) at runtime.
FROM node:22-slim AS build
WORKDIR /app
RUN corepack enable && apt-get update && apt-get install -y --no-install-recommends openssl \
  && rm -rf /var/lib/apt/lists/*
COPY . .
RUN pnpm install --frozen-lockfile
RUN pnpm db:generate
RUN pnpm --filter @pricepilot/api build

FROM node:22-slim AS runtime
WORKDIR /app
RUN corepack enable && apt-get update && apt-get install -y --no-install-recommends openssl \
  && rm -rf /var/lib/apt/lists/*
ENV NODE_ENV=production
COPY --from=build /app /app
EXPOSE 3001
# Apply pending migrations, then start the bundled server.
CMD ["sh", "-c", "pnpm --filter @pricepilot/db db:deploy && node apps/api/dist/index.js"]
