# Copy to .env for local development (docker-compose in infra/ provides these).

# --- Database (Postgres) ---
DATABASE_URL="postgresql://pricepilot:pricepilot@localhost:5432/pricepilot?schema=public"

# --- Cache / queue (Redis) ---
REDIS_URL="redis://localhost:6379"

# --- API ---
API_HOST="0.0.0.0"
API_PORT="3001"
# Comma-separated list of allowed CORS origins for the web app.
CORS_ORIGIN="http://localhost:5173"

# --- Web (Vite) ---
# Base URL the PWA uses to reach the API.
VITE_API_URL="http://localhost:3001"

# --- Intelligence layer (packages/intel) ---
# Enables the Claude extraction fallback (tier 4) + cross-vendor match tie-break.
ANTHROPIC_API_KEY=""
# Optional model override (defaults to claude-sonnet-4-6).
ANTHROPIC_MODEL=""

# --- Vendor adapters (lead with API-friendly vendors) ---
# eBay Browse API OAuth application token (client-credentials grant). When set,
# eBay item URLs use the official API tier instead of structured-data scraping.
EBAY_OAUTH_TOKEN=""
# Best Buy developer API key. When set, Best Buy product URLs use the API tier.
BESTBUY_API_KEY=""
# Amazon adapter is opt-in / off-by-default. Leave disabled unless you accept the
# ToS risk documented in README.md and PLAN.md.
ENABLE_AMAZON_ADAPTER="false"

# --- Watcher (apps/worker) ---
# How often the scheduler enqueues due offers, and how many per tick.
SCHEDULER_INTERVAL_MS="60000"
SCHEDULER_BATCH="50"

# --- Web Push (VAPID) ---
# Generate a keypair with: npx web-push generate-vapid-keys
# The public key is served to the web app; the private key is used by the worker.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:alerts@pricepilot.local"

# --- Headless (Playwright) fallback tier ---
# Opt-in tier-3 adapter for JS-rendered pages. playwright-core does NOT download
# browsers, so point it at a system browser via channel or executable path.
ENABLE_PLAYWRIGHT="false"
PLAYWRIGHT_CHANNEL=""            # e.g. "chrome"
PLAYWRIGHT_EXECUTABLE_PATH=""
